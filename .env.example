# OpenClaw(飞书/LLM 渠道的)环境变量样板
# 复制为 .env 并填写真实值

# ---- LLM (OpenAI 兼容) ----
# 任何兼容 OpenAI Chat Completions 接口的服务都行:
#   - OpenAI:    https://api.openai.com/v1
#   - DeepSeek:  https://api.deepseek.com/v1
#   - Moonshot:  https://api.moonshot.cn/v1
#   - Ollama:    http://localhost:11434/v1
#   - OneAPI / NewAPI 自部署网关
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ---- 飞书 (Lark) Bot ----
# 创建自建应用后, 在「事件订阅」里把 Verification Token / Encrypt Key 填好
# 权限: im:message, im:message.group_at_msg, im:message.p2p_msg
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=
# 长连接(免公网 IP) 默认开启; 如改用 Webhook 把 LARK_USE_WS 设为 false 并配置 LARK_WEBHOOK_URL
LARK_USE_WS=true
# LARK_WEBHOOK_URL=https://your.domain.com/lark/callback

# ---- 行为参数 ----
AGENT_SYSTEM_PROMPT=你叫 Claw, 是一个乐于助人、简洁高效的私人 AI 助理。可以使用工具来获取信息或执行任务。
AGENT_MAX_TOOL_ITERATIONS=8
AGENT_HISTORY_WINDOW=20

# ---- 记忆存储 ----
MEMORY_DIR=./.openclaw_memory
